#!/bin/zsh
# ============================================================
# cc — Claude Code 项目切换器（手机友好）
#
# 用法:
#   cc          显示项目菜单，输入数字进入
#   cc 3        直接进入第 3 个项目
#   cc -l       仅列出项目（不启动 Claude Code）
#   cc -e       用默认编辑器打开项目配置文件
#   cc -h       显示帮助
# ============================================================

# 配置文件路径（与脚本同目录）
SCRIPT_DIR="${0:A:h}"
CONF_FILE="$SCRIPT_DIR/projects.conf"
# monorepo 根目录（cc 在 AITaskMgr/ 下，上一级就是仓库根）
MONOREPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- 颜色 ---
GREEN='\033[32m'
CYAN='\033[36m'
YELLOW='\033[33m'
DIM='\033[2m'
RED='\033[31m'
BOLD='\033[1m'
RESET='\033[0m'

# --- 全局数组 ---
typeset -g -a PROJ_NAMES PROJ_DIRS
PROJ_NAMES=()
PROJ_DIRS=()

# --- 加载项目列表 ---
load_projects() {
    PROJ_NAMES=()
    PROJ_DIRS=()

    if [[ ! -f "$CONF_FILE" ]]; then
        echo "${RED}❌ 配置文件未找到: $CONF_FILE${RESET}"
        return 1
    fi

    local line name dir
    while IFS= read -r line; do
        # 跳过空行和注释
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        # 解析 name | dir
        name="${line%%|*}"
        dir="${line##*|}"
        name="${name## }"
        name="${name%% }"
        dir="${dir## }"
        dir="${dir%% }"
        # 展开 ~、$HOME、$MONOREPO_ROOT
        dir="${dir/#\~/$HOME}"
        dir="${dir/\$HOME/$HOME}"
        dir="${dir/\$MONOREPO_ROOT/$MONOREPO_ROOT}"
        PROJ_NAMES+=("$name")
        PROJ_DIRS+=("$dir")
    done < "$CONF_FILE"
}

# --- 显示菜单 ---
show_menu() {
    clear 2>/dev/null || true
    echo "${BOLD}${CYAN}📁 选择项目 ${DIM}(Claude Code)${RESET}"
    echo ""

    integer i=1
    for name in "${PROJ_NAMES[@]}"; do
        local short_dir="${PROJ_DIRS[$i]#$HOME/}"
        printf "  ${GREEN}${BOLD}%2d${RESET}. ${YELLOW}%-22s${RESET} ${DIM}%s${RESET}\n" "$i" "$name" "$short_dir"
        ((i++))
    done

    echo ""
    echo "  ${DIM}0. 当前目录${RESET}"
    echo ""
}

# --- 启动 Claude Code ---
launch_claude() {
    local target="$1"
    local label="$2"

    if [[ ! -d "$target" ]]; then
        echo "${RED}❌ 目录不存在: $target${RESET}"
        return 1
    fi

    echo "🚀 启动 Claude Code ${DIM}@ ${label}${RESET}"
    echo "   ${DIM}${target}${RESET}"
    sleep 0.5

    cd "$target" || return 1
    exec claude --permission-mode bypassPermissions
}

# --- 主逻辑 ---
main() {
    load_projects || return 1

    integer total="${#PROJ_NAMES[@]}"

    case "${1:-}" in
        -h|--help)
            echo "${BOLD}用法:${RESET} cc [数字|选项]"
            echo ""
            echo "  cc          显示项目菜单"
            echo "  cc 3        直接进入项目 3"
            echo "  cc -l       仅列出项目"
            echo "  cc -e       编辑项目配置文件"
            echo "  cc -h       显示帮助"
            echo ""
            echo "配置文件: $CONF_FILE"
            return 0
            ;;
        -l|--list)
            echo "${BOLD}项目列表:${RESET}"
            echo ""
            integer i=1
            for name in "${PROJ_NAMES[@]}"; do
                local dir="${PROJ_DIRS[$i]}"
                local mark="${GREEN}✓${RESET}"
                [[ ! -d "$dir" ]] && mark="${RED}✗${RESET}"
                printf "  %2d. %-25s ${mark}  %s\n" "$i" "$name" "$dir"
                ((i++))
            done
            return 0
            ;;
        -e|--edit)
            ${EDITOR:-vim} "$CONF_FILE"
            return 0
            ;;
        "")
            show_menu
            ;;
        *)
            if [[ "$1" =~ ^[0-9]+$ ]]; then
                if [[ "$1" -ge 1 && "$1" -le "$total" ]]; then
                    launch_claude "${PROJ_DIRS[$1]}" "${PROJ_NAMES[$1]}"
                    return 0
                elif [[ "$1" -eq 0 ]]; then
                    echo "📍 保持在当前目录: $(pwd)"
                    exec claude --permission-mode bypassPermissions
                else
                    echo "${RED}❌ 无效编号: $1（有效范围: 1-$total）${RESET}"
                    return 1
                fi
            else
                echo "${RED}❌ 无效参数: $1（输入 cc -h 查看帮助）${RESET}"
                return 1
            fi
            ;;
    esac

    # 交互模式：读取输入
    printf "${GREEN}输入数字 ${DIM}(1-%d, 0=当前目录)${RESET}: " "$total"
    read choice

    if [[ -z "$choice" ]]; then
        echo "👋 已取消"
        return 0
    fi

    if [[ ! "$choice" =~ ^[0-9]+$ ]]; then
        echo "${RED}❌ 请输入数字${RESET}"
        return 1
    fi

    if [[ "$choice" -eq 0 ]]; then
        echo "📍 保持在当前目录: $(pwd)"
        exec claude --permission-mode bypassPermissions
    elif [[ "$choice" -ge 1 && "$choice" -le "$total" ]]; then
        launch_claude "${PROJ_DIRS[$choice]}" "${PROJ_NAMES[$choice]}"
    else
        echo "${RED}❌ 无效编号: $choice（有效范围: 1-$total）${RESET}"
        return 1
    fi
}

main "$@"
